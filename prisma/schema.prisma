generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // วางลิงก์ตรงๆ ลงในเครื่องหมายคำพูดเลยครับ
  url      = "ลิงก์_DATABASE_URL_จาก_Supabase_ของคุณ" 
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String
  createdAt DateTime @default(now())
}