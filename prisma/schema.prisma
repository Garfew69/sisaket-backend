// 1. ตัวสร้าง Client (ต้องมีอันเดียว)
generator client {
  provider = "prisma-client-js"
}

// 2. การเชื่อมต่อฐานข้อมูล (ต้องระบุ url)
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 3. ตารางผู้ใช้งาน
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   // 'admin' หรือ 'staff'
  createdAt DateTime @default(now())
}